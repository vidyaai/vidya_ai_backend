# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/vidya_ai

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_s3_bucket_name
AWS_REGION=us-east-1

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Web Search API Configuration (for augmenting answers with internet research)
# Choose ONE provider - Tavily is recommended for AI/LLM applications
#
# Option 1: Tavily API (RECOMMENDED)
# Get API key from: https://tavily.com
# Cost: ~$0.005 per search, optimized for AI use cases
TAVILY_API_KEY=your_tavily_api_key
#
# Option 2: Serper API (Google Search - cheaper alternative)
# Get API key from: https://serper.dev
# Cost: ~$0.001 per search
# SERPER_API_KEY=your_serper_api_key
#
# Option 3: Google Custom Search API
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_SEARCH_API_KEY=your_google_api_key
# GOOGLE_CSE_ID=your_custom_search_engine_id

# Deepgram Configuration (for audio processing)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Cloud Credentials for Forms API (choose ONE method)
# Method 1: JSON content as environment variable (recommended for production)
# GOOGLE_CLOUD_CREDENTIALS_JSON={"type": "service_account", "project_id": "your-project", ...}

# Method 2: Path to service account file (alternative)
# GOOGLE_CLOUD_CREDENTIALS_FILE=/secure/path/to/vidyaai-forms-integrations-0270b6b160e0.json

# Stripe Configuration (for payments)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Brevo (email marketing) — pushes new signups into the welcome list
BREVO_API_KEY=your_brevo_api_key
BREVO_LIST_ID=3

# Brevo transactional sender (welcome, enrollment, course-update emails).
# BREVO_SENDER_EMAIL must be a verified sender in the Brevo dashboard, or its
# domain must be authenticated — unverified senders are rejected.
BREVO_SENDER_EMAIL=admin@vidyaai.co
BREVO_SENDER_NAME=Vidya AI Inc.

# HS256 secret for signed course-invitation tokens (emailed accept links).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
INVITE_TOKEN_SECRET=rBwVRe6cS1mfSth26oUiOQ54uarNM-CMvI3H8uxy2gyoIRmhQoJKc8SwlP7NCjnm

# Frontend base URL used to build links in transactional emails.
FRONTEND_BASE_URL=http://localhost:3000

# Application Settings
ENVIRONMENT=development
DEBUG=true