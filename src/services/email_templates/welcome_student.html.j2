{% extends "_base.html.j2" %}
{% block content %}
<h2 style="margin-top: 0;">Welcome, {{ first_name }}!</h2>
<p>You're all set up as a <strong>student</strong> on Vidya AI.</p>
<p>From your dashboard you can join courses, work on assignments, and use the AI tutor on lecture videos.</p>
<p style="margin: 24px 0;">
  <a href="{{ frontend_url }}" style="background: #1a73e8; color: #fff; text-decoration: none; padding: 10px 18px; border-radius: 4px; display: inline-block;">
    Open Vidya AI
  </a>
</p>
<p>If your instructor has already invited you to a course, you'll see it on your dashboard automatically.</p>
{% endblock %}
